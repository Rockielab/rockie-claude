{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-report.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/learn-capture.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/deadend-capture.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/correction-detect.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/load-relevant-rules.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/load-relevant-deadends.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stuck-detector.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/stage-inject.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/budget-reconcile.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/doc-guard.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-gate.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/pre-train-gate.sh" },
          { "type": "command", "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/budget-gate.sh" }
        ]
      }
    ]
  }
}
